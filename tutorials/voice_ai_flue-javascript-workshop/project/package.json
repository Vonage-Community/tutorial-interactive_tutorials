{
  "name": "sample-voice-node-learning_server",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "flue:dev": "flue dev --target node --env .env --port 3000",
    "flue:build": "flue build --target node",
    "flue:run": "flue run hello-world --target node --id local-demo --payload '{\"message\":\"Say hello from my first Flue agent.\"}' --env .env"
  },
  "dependencies": {
    "@vonage/server-sdk": "^3.27.0",
    "@flue/runtime": "1.0.0-beta.9",
    "@flue/sdk": "1.0.0-beta.9",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.9"
  },
  "type": "module"
}
