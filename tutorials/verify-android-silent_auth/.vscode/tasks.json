{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Launch Live Preview",
            "type": "shell",
            "command": "echo 'Triggering Local Preview Workspace Canvas...'",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            // This safely forces VS Code to trigger the Live Preview layout command internally
            "serverReadyAction": {
                "action": "runCommand",
                "command": "livePreview.start"
            }
        }
    ]
}
