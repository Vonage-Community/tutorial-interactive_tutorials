{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "baseUrl": ".",
    "types": ["node", "jest"],
    "paths": {
      "@api-lib": ["../libs/api/src"],
      "@api-lib/*": ["../libs/api/src/*"],
      "@common": ["../libs/common/src"],
      "@common/*": ["../libs/common/src/*"],
      "@common-test": ["../libs/common/test"],
      "@common-test/*": ["../libs/common/test/*"],
      "@node": ["../libs/common/srcNode"],
      "@node/*": ["../libs/common/srcNode/*"],
      "@node-test": ["../libs/common/testNode"],
      "@node-test/*": ["../libs/common/testNode/*"]
    }
  }
}
