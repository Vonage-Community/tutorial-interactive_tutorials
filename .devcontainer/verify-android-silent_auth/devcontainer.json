json{
    "name": "Tutorial: verify-android-silent_auth",
    "image": "://microsoft.com",
    "workspaceFolder": "/workspaces/tutorial-interactive_tutorials/tutorials/verify-android-silent_auth",
    "waitFor": "onCreateCommand",
    "updateContentCommand": "npm install",
    "postCreateCommand": "",
    
    // MOVE THE COMMAND TO THE FRONT: Run the preview window command instantly before booting the servers
    "postAttachCommand": "code --command livePreview.start && nohup ./node_modules/.bin/http-server steps -p 1234 --cors -c-1 > /dev/null 2>&1 & cd project && (sleep 4 && echo -e '\\n\\n🚀 APPLICATION READY:\\nhttps://${CODESPACE_NAME}-3000.app.github.dev\\n\\n' &) && (nohup sh -c 'sleep 5 && gh codespace ports visibility 3000:public -c $CODESPACE_NAME' > /dev/null 2>&1 &) && npm start",
    
    "forwardPorts": [
        "3000"
    ],
    "portsAttributes": {
        "3000": {
            "label": "My Backend Service",
            "onAutoForward": "notify",
            "visibility": "public"
        },
        "1234": {
            "label": "Internal Tutorial Server",
            "onAutoForward": "ignore",
            "elevationRequired": false
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.live-server"
            ],
            "settings": {
                "livePreview.defaultPreviewPath": "http://127.0.0.1:1234",
                "editor.formatOnSave": true,
                "files.exclude": {
                    "node_modules": true,
                    "dist": true,
                    "steps": true,
                    ".devcontainer": true,
                    ".vscode": true,
                    "package.json": true,
                    "package-lock.json": true,
                    "tutorial-config.json": true,
                    "tsconfig.json": true,
                    "astro.config.mjs": true,
                    ".git": true,
                    ".DS_Store": true,
                    "project/setup-project.js": true,
                    "vonage-toolbar": true,
                    "src": true,
                    "markdoc.config.mjs": true,
                    ".astro": true,
                    "README.md": true,
                    "public": true,
                    "download-toolbar.js": true
                },
                "terminal.integrated.cwd": "${workspaceFolder}/project"
            }
        },
        "codespaces": {
            "openFiles": [
                "project/server.js"
            ]
        }
    }
}
