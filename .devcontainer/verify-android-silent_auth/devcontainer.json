{
    "name": "Tutorial: verify-android-silent_auth",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
    "workspaceFolder": "/workspaces/tutorial-interactive_tutorials/tutorials/verify-android-silent_auth",
    "waitFor": "onCreateCommand",
    "updateContentCommand": "npm install",
    "postCreateCommand": "",

    // 1. UPDATE POSTCREATE: Replaces tasks.json with a native workspace layout debugger configuration
    "postCreateCommand": "mkdir -p .vscode && echo '{\"version\":\"0.2.0\",\"configurations\":[{\"type\":\"chrome\",\"request\":\"launch\",\"name\":\"Open Tutorial\",\"url\":\"http://127.0.0.1:1234\",\"webRoot\":\"${workspaceFolder}\",\"presentation\":{\"group\":\"navigation\",\"order\":1}}]}' > .vscode/launch.json",
    
    // 2. STABLE SERVER CHAINS: Simple server boots, completely separated from unstable UI scripting
    "postAttachCommand": "nohup ./node_modules/.bin/http-server steps -p 1234 --cors -c-1 > /dev/null 2>&1 & cd project && (sleep 4 && echo -e '\\n\\n🚀 APPLICATION READY:\\nhttps://${CODESPACE_NAME}-3000.app.github.dev\\n\\n' &) && (nohup sh -c 'sleep 5 && gh codespace ports visibility 3000:public -c $CODESPACE_NAME' > /dev/null 2>&1 &) && npm start",
                       
    "forwardPorts": [
        "3000"
    ],
    "portsAttributes": {
        "3000": {
            "label": "My Backend Service",
            "onAutoForward": "notify",
            "visibility": "public"
        },
        "1234": {
            "label": "Internal Tutorial Server",
            "onAutoForward": "ignore",
            "elevationRequired": false
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.live-server"
            ],
            "settings": {
                "livePreview.defaultPreviewPath": "http://127.0.0.1:1234",
                "editor.formatOnSave": true,
                "files.exclude": {
                    "node_modules": true,
                    "dist": true,
                    "steps": true,
                    ".devcontainer": true,
                    ".vscode": false,
                    "package.json": true,
                    "package-lock.json": true,
                    "tutorial-config.json": true,
                    "tsconfig.json": true,
                    "astro.config.mjs": true,
                    ".git": true,
                    ".DS_Store": true,
                    "project/setup-project.js": true,
                    "vonage-toolbar": true,
                    "src": true,
                    "markdoc.config.mjs": true,
                    ".astro": true,
                    "README.md": true,
                    "public": true,
                    "download-toolbar.js": true
                },
                "terminal.integrated.cwd": "${workspaceFolder}/project",
                "task.allowAutomaticTasks": "on"
            }
        },
        "codespaces": {
            "openFiles": [
                "project/server.js"
            ]
        }
    }
}
